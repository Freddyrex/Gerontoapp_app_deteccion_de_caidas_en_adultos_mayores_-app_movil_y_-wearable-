<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ═══════════════════════════════════════
         Tema principal
    ═══════════════════════════════════════ -->
    <style name="Theme.Siag" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_black</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="android:colorBackground">@color/background_light</item>
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
        <!-- Estilos globales Material -->
        <item name="materialButtonStyle">@style/Widget.Siag.Button.Primary</item>
        <item name="textInputStyle">@style/Widget.Siag.TextInputLayout</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Siag.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Siag.LargeComponent</item>
    </style>

    <style name="Theme.Siag.Emergencia" parent="Theme.Siag">
        <item name="android:windowShowWallpaper">false</item>
    </style>

    <!-- ═══════════════════════════════════════
         Shapes (esquinas globales)
    ═══════════════════════════════════════ -->
    <style name="ShapeAppearance.Siag.MediumComponent" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.Siag.LargeComponent" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <!-- ═══════════════════════════════════════
         TextInputLayout global
    ═══════════════════════════════════════ -->
    <style name="Widget.Siag.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/accent_cyan</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <!-- ═══════════════════════════════════════
         Text appearances (jerarquía)
    ═══════════════════════════════════════ -->
    <style name="TextAppearance.Siag.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Siag.Subtitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.Siag.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Siag.Label" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/accent_cyan</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <!-- ═══════════════════════════════════════
         Botón primario – cápsula rellena oscura
    ═══════════════════════════════════════ -->
    <style name="Widget.Siag.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/button_text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="cornerRadius">32dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">4dp</item>
    </style>

    <!-- ═══════════════════════════════════════
         Botón secundario – contorno redondeado
    ═══════════════════════════════════════ -->
    <style name="Widget.Siag.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="cornerRadius">32dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- ═══════════════════════════════════════
         Botón de acción (cyan) – solo en formularios
    ═══════════════════════════════════════ -->
    <style name="Widget.Siag.Button.Accent" parent="Widget.Siag.Button.Primary">
        <item name="android:background">@drawable/bg_button_accent</item>
        <item name="android:textColor">@color/setup_bg_start</item>
    </style>

    <!-- ═══════════════════════════════════════
         Card
    ═══════════════════════════════════════ -->
    <style name="Widget.Siag.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/card_white</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">3dp</item>
        <item name="contentPaddingLeft">16dp</item>
        <item name="contentPaddingTop">14dp</item>
        <item name="contentPaddingRight">16dp</item>
        <item name="contentPaddingBottom">14dp</item>
    </style>

    <!-- ═══════════════════════════════════════
         Alias de compatibilidad
    ═══════════════════════════════════════ -->
    <style name="Widget.Siag.Button" parent="Widget.Siag.Button.Primary" />
    <style name="Widget.Siag" parent="Theme.Siag" />

</resources>