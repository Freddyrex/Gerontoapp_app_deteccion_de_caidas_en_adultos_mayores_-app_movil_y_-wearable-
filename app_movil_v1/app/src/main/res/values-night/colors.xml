<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ══ Fondos ══ -->
    <color name="background_light">#0D0E14</color>
    <color name="toolbar_light">#C8C8C8</color>
    <color name="toolbar_dark">#0D0E14</color>
    <color name="card_white">#1A1D2E</color>
    <color name="surface_card">#1A1D2E</color>

    <!-- ══ Textos ══ -->
    <color name="text_primary">#FFFFFF</color>
    <color name="text_secondary">#8A91B4</color>
    <color name="text_on_dark">#FFFFFF</color>

    <!-- ══ Acentos ══ -->
    <!-- En dark mode NO invertimos accent_black a blanco — lo dejamos como cyan
         para que los botones que lo usen sean visibles -->
    <color name="accent_black">#0D0E14</color>
    <color name="accent_cyan">#00C2FF</color>
    <color name="cyan_accent">#00C2FF</color>
    <color name="accent_violet">#7B2FFF</color>

    <!-- ══ Estado ══ -->
    <color name="color_grave">#EF5350</color>
    <color name="color_media">#FFA726</color>
    <color name="color_leve">#66BB6A</color>
    <color name="logout_red">#EF5350</color>

    <!-- ══ Niveles ══ -->
    <color name="nivel_1">#00C2FF</color>
    <color name="nivel_2">#FFA726</color>
    <color name="nivel_3">#EF5350</color>

    <!-- ══ Superficies ══ -->
    <color name="divider_gray">#2A2D3E</color>
    <color name="bottom_bar_bg">#0D0E14</color>
    <color name="setup_bg_start">#0D0E14</color>
    <color name="setup_bg_end">#1A1F35</color>

    <!-- ══ Botones ══ -->
    <!-- El botón primario en dark mode usa el degradado oscuro del drawable
         (bg_button_primary.xml hardcodea los colores, no usa esta variable)
         Pero crearBotonPlano sí usa accent_black para el btn normal → lo dejamos oscuro
         para que en dark mode los btns usen cyan (lógica en crearBotonPlano) -->
    <color name="button_bg_primary">#0D0E14</color>
    <color name="button_bg_accent">#00C2FF</color>
    <color name="button_text_primary">#FFFFFF</color>

    <!-- ══ Compatibilidad ══ -->
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>
</resources>
