<?xml version="1.0" encoding="utf-8"?>
<!-- Botón secundario: pill blanco con borde sutil para modo claro -->
<!-- En modo oscuro la ripple del Material theme aplica el tint correcto -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <stroke android:width="1.5dp" android:color="@color/divider_gray" />
    <corners android:radius="32dp" />
    <padding android:left="20dp" android:top="0dp" android:right="20dp" android:bottom="0dp" />
</shape>
