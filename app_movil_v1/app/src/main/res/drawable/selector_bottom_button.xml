<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Active: selected or activated -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/cyan_accent" />
            <corners android:radius="24dp" />
            <padding android:left="12dp" android:top="8dp" android:right="12dp" android:bottom="8dp" />
        </shape>
    </item>
    <item android:state_activated="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/cyan_accent" />
            <corners android:radius="24dp" />
            <padding android:left="12dp" android:top="8dp" android:right="12dp" android:bottom="8dp" />
        </shape>
    </item>

    <!-- Default (inactive) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/card_white" />
            <stroke android:width="1dp" android:color="@color/divider_gray" />
            <corners android:radius="24dp" />
            <padding android:left="12dp" android:top="8dp" android:right="12dp" android:bottom="8dp" />
        </shape>
    </item>
</selector>
