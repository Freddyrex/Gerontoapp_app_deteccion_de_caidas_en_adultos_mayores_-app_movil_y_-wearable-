<?xml version="1.0" encoding="utf-8"?>
<!-- Barra inferior con esquinas superiores muy redondeadas, estilo "floating pill" -->
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <solid android:color="@color/bottom_bar_bg" />
    <corners
        android:topLeftRadius="28dp"
        android:topRightRadius="28dp"
        android:bottomLeftRadius="28dp"
        android:bottomRightRadius="28dp" />
    <padding android:left="16dp" android:top="10dp" android:right="16dp" android:bottom="10dp" />
    <stroke android:width="1dp" android:color="#22FFFFFF" />
</shape>
